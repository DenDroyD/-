Attribute VB_Name = "числапрописью"
Function пропись(сумма As Double) As String
    ' Проверка на слишком большие числа
    If Abs(сумма) > 9999999999999.99 Then
        пропись = "Слишком большое число!"
        Exit Function
    End If
    
    ' Обработка отрицательных чисел
    If сумма < 0 Then
        пропись = "минус " & пропись(Abs(сумма))
        Exit Function
    End If
    
    ' Основные переменные
    Dim рубли As Currency
    Dim копейки As Long
    Dim результат As String
    Dim разряд As Integer
    Dim блокЧисла As Long
    Dim формаСлова As Integer
    
    ' Округляем до копеек
    сумма = Round(сумма, 2)
    
    ' Разделяем рубли и копейки
    рубли = Int(сумма)
    копейки = Round((сумма - рубли) * 100)
    
    ' Коррекция копеек (если после округления стало 100)
    If копейки = 100 Then
        рубли = рубли + 1
        копейки = 0
    End If
    
    ' Базовые слова
    Dim единицы(0 To 19) As String
    единицы(0) = "ноль"
    единицы(1) = "один"
    единицы(2) = "два"
    единицы(3) = "три"
    единицы(4) = "четыре"
    единицы(5) = "пять"
    единицы(6) = "шесть"
    единицы(7) = "семь"
    единицы(8) = "восемь"
    единицы(9) = "девять"
    единицы(10) = "десять"
    единицы(11) = "одиннадцать"
    единицы(12) = "двенадцать"
    единицы(13) = "тринадцать"
    единицы(14) = "четырнадцать"
    единицы(15) = "пятнадцать"
    единицы(16) = "шестнадцать"
    единицы(17) = "семнадцать"
    единицы(18) = "восемнадцать"
    единицы(19) = "девятнадцать"
    
    Dim десятки(2 To 9) As String
    десятки(2) = "двадцать"
    десятки(3) = "тридцать"
    десятки(4) = "сорок"
    десятки(5) = "пятьдесят"
    десятки(6) = "шестьдесят"
    десятки(7) = "семьдесят"
    десятки(8) = "восемьдесят"
    десятки(9) = "девяносто"
    
    ' Разряды чисел
    Dim разряды As Variant
    разряды = Array( _
        Array("", "", ""), _
        Array("тысяча", "тысячи", "тысяч"), _
        Array("миллион", "миллиона", "миллионов"), _
        Array("миллиард", "миллиарда", "миллиардов"), _
        Array("триллион", "триллиона", "триллионов") _
    )
    
    ' Обработка нулевых рублей
    If рубли = 0 Then
        результат = "ноль"
    Else
        разряд = 0
        Do While рубли > 0
            блокЧисла = рубли Mod 1000
            рубли = рубли \ 1000
            
            If блокЧисла > 0 Then
                ' Проверка на поддержку разрядов
                If разряд > UBound(разряды) Then
                    пропись = "Число слишком большое!"
                    Exit Function
                End If
                
                Dim часть As String
                часть = ПреобразоватьСотни(блокЧисла, разряд = 1, единицы, десятки)
                формаСлова = ОпределитьФормуСлова(блокЧисла)
                
                ' Добавляем разряд (тыс./млн и т.д.)
                If разряд > 0 Then
                    часть = часть & " " & разряды(разряд)(формаСлова)
                End If
                
                ' Собираем результат
                If результат <> "" Then
                    результат = часть & " " & результат
                Else
                    результат = часть
                End If
            End If
            разряд = разряд + 1
        Loop
    End If
    
    ' Добавляем валюту и копейки
    пропись = Trim(результат) & " " & ПолучитьВалюту(сумма, копейки)
End Function

' Преобразует трёхзначное число (0-999)
Private Function ПреобразоватьСотни(число As Long, дляТысяч As Boolean, единицы() As String, десятки() As String) As String
    Dim сотни As Integer, десяток As Integer, единица As Integer
    Dim текст As String
    текст = ""
    
    сотни = число \ 100
    десяток = (число Mod 100) \ 10
    единица = число Mod 10
    
    ' Сотни
    If сотни > 0 Then
        Select Case сотни
            Case 1: текст = "сто "
            Case 2: текст = "двести "
            Case 3: текст = "триста "
            Case 4: текст = "четыреста "
            Case 5: текст = "пятьсот "
            Case 6: текст = "шестьсот "
            Case 7: текст = "семьсот "
            Case 8: текст = "восемьсот "
            Case 9: текст = "девятьсот "
        End Select
    End If
    
    ' Десятки и единицы
    If (число Mod 100) < 20 Then
        If число Mod 100 > 0 Then
            If дляТысяч Then
                ' Особые формы для тысяч
                Select Case число Mod 100
                    Case 1: текст = текст & "одна"
                    Case 2: текст = текст & "две"
                    Case Else: текст = текст & единицы(число Mod 100)
                End Select
            Else
                текст = текст & единицы(число Mod 100)
            End If
        End If
    Else
        ' Десятки
        If десяток >= 2 Then
            текст = текст & десятки(десяток)
        End If
        
        ' Единицы
        If единица > 0 Then
            If Len(текст) > 0 Then текст = текст & " "
            If дляТысяч Then
                ' Особые формы для тысяч
                Select Case единица
                    Case 1: текст = текст & "одна"
                    Case 2: текст = текст & "две"
                    Case Else: текст = текст & единицы(единица)
                End Select
            Else
                текст = текст & единицы(единица)
            End If
        End If
    End If
    
    ПреобразоватьСотни = Trim(текст)
End Function

' Определяет форму разряда (1 рубль, 2 рубля, 5 рублей)
Private Function ОпределитьФормуСлова(n As Long) As Integer
    n = n Mod 100
    If n >= 11 And n <= 19 Then
        ОпределитьФормуСлова = 2
    Else
        Select Case n Mod 10
            Case 1: ОпределитьФормуСлова = 0
            Case 2, 3, 4: ОпределитьФормуСлова = 1
            Case Else: ОпределитьФормуСлова = 2
        End Select
    End If
End Function

' Формирует окончательную строку с валютой
Private Function ПолучитьВалюту(рубли As Double, копейки As Long) As String
    ' Рубли
    Dim остатокРублей As Long
    остатокРублей = CLng(рубли) Mod 100
    
    Dim текстРубли As String
    If остатокРублей >= 11 And остатокРублей <= 19 Then
        текстРубли = "рублей"
    Else
        Select Case остатокРублей Mod 10
            Case 1: текстРубли = "рубль"
            Case 2, 3, 4: текстРубли = "рубля"
            Case Else: текстРубли = "рублей"
        End Select
    End If
    
    ' Копейки - всегда выводим двузначным числом
    Dim текстКопейки As String
    If копейки >= 11 And копейки <= 19 Then
        текстКопейки = "копеек"
    Else
        Select Case копейки Mod 10
            Case 1: текстКопейки = "копейка"
            Case 2, 3, 4: текстКопейки = "копейки"
            Case Else: текстКопейки = "копеек"
        End Select
    End If
    
    ' Форматируем копейки как двузначное число (01, 05, 10 и т.д.)
    Dim форматКопейки As String
    форматКопейки = Format(копейки, "00")
    
    ' Собираем результат
    ПолучитьВалюту = текстРубли & " " & форматКопейки & " " & текстКопейки
End Function

